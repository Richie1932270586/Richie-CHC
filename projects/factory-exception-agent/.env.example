APP_NAME=Factory Exception Agent
API_HOST=127.0.0.1
API_PORT=8000
LOG_LEVEL=INFO

MOCK_MODE=false
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=qwen3.5:9b
LLM_API_KEY=ollama
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=120
LLM_REASONING_EFFORT=none
LLM_MAX_TOKENS=480

AGENT_MODE=hybrid
RAG_ENABLED=true
RAG_PROFILE=light
RAG_TOP_K=4
RAG_FULL_TOP_K=6
CHUNK_SIZE=260
CHUNK_OVERLAP=50
RERANK_ENABLED=true
EMBEDDING_PROVIDER=local-bow
EMBEDDING_MODEL=token-frequency-v1

KB_DIR=data/knowledge_base
IMPORTED_KB_DIR=data/knowledge_base/imported_office
INDEX_FILE=data/indexes/kb_index.json
IMPORT_MANIFEST_FILE=data/indexes/import_manifest.json
INVENTORY_FILE=data/mock_tables/inventory.csv
INCIDENTS_FILE=data/mock_tables/incidents.csv
OWNERS_FILE=data/mock_tables/owners.csv
TICKET_TEMPLATES_FILE=data/mock_tables/ticket_templates.json
EVAL_CASES_FILE=data/eval_cases/eval_cases.json

AUTO_REBUILD_INDEX=true
ALLOW_CORS_ALL=true
